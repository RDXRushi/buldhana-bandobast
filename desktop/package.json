{
  "name": "buldhana-bandobast-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Digital Police Bandobast Management System — Desktop Offline Edition for Buldhana District Police",
  "main": "main.js",
  "author": "Buldhana District Police",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win --x64 --publish=never"
  },
  "build": {
    "appId": "in.buldhana.policebandobast",
    "productName": "Buldhana Police Bandobast",
    "directories": { "output": "dist" },
    "files": [
      "main.js",
      "preload.js",
      "server.js",
      "renderer/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/qrcode/**/*"
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "artifactName": "BuldhanaBandobast-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Buldhana Bandobast"
    }
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "lowdb": "^1.0.0",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.3",
    "exceljs": "^4.4.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  }
}
