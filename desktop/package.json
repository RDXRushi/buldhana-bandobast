{
  "name": "buldhana-bandobast-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Digital Police Bandobast Management System — Desktop Offline Edition for Buldhana District Police",
  "main": "main.js",
  "author": "Buldhana District Police",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win --x64 --publish=never"
  },
  "build": {
    "appId": "in.buldhana.policebandobast",
    "productName": "Buldhana Police Bandobast",
    "publish": null,
    "directories": { "output": "dist" },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      { "from": "resources/mongodb", "to": "mongodb" },
      { "from": "resources/server",  "to": "server"  }
    ],
    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "artifactName": "BuldhanaBandobast-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Buldhana Bandobast"
    },
    "portable": {
      "artifactName": "BuldhanaBandobast-Portable-${version}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  }
}
